<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light_grey">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Top Header -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/primary_blue"
                android:paddingTop="48dp"
                android:paddingBottom="48dp"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:id="@+id/iv_logo_building"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_home_outline"
                    app:tint="@color/white"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:id="@+id/tv_logo_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ReportIt"
                    android:textColor="@color/white"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp"
                    app:layout_constraintTop_toTopOf="@id/iv_logo_building"
                    app:layout_constraintBottom_toBottomOf="@id/iv_logo_building"
                    app:layout_constraintStart_toEndOf="@id/iv_logo_building" />

                <ImageView
                    android:id="@+id/iv_menu"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_menu_outline"
                    android:padding="2dp"
                    app:layout_constraintTop_toTopOf="@id/iv_logo_building"
                    app:layout_constraintBottom_toBottomOf="@id/iv_logo_building"
                    app:layout_constraintEnd_toEndOf="parent" />

                <ImageView
                    android:id="@+id/iv_bell"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_notifications_outline"
                    android:layout_marginEnd="16dp"
                    android:padding="2dp"
                    app:layout_constraintTop_toTopOf="@id/iv_menu"
                    app:layout_constraintBottom_toBottomOf="@id/iv_menu"
                    app:layout_constraintEnd_toStartOf="@id/iv_menu" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- White Container Wrapper -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_rounded_top_white"
                android:layout_marginTop="-24dp"
                android:padding="24dp">

                <!-- Stats Card -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/card_stats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_input"
                    android:paddingVertical="16dp"
                    android:paddingHorizontal="8dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:baselineAligned="false">

                        <!-- Pending -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <FrameLayout
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@drawable/bg_rounded_top_white"
                                android:backgroundTint="#FFFBEB">
                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_clock" />
                            </FrameLayout>

                            <TextView
                                android:id="@+id/tv_pending_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="2"
                                android:textColor="@color/black"
                                android:textStyle="bold"
                                android:textSize="18sp"
                                android:layout_marginTop="8dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pending"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <!-- Active -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <FrameLayout
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@drawable/bg_rounded_top_white"
                                android:backgroundTint="#EFF6FF">
                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_trending_up" />
                            </FrameLayout>

                            <TextView
                                android:id="@+id/tv_active_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="1"
                                android:textColor="@color/black"
                                android:textStyle="bold"
                                android:textSize="18sp"
                                android:layout_marginTop="8dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Active"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <!-- Complete -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <FrameLayout
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@drawable/bg_rounded_top_white"
                                android:backgroundTint="#ECFDF5">
                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_check_circle" />
                            </FrameLayout>

                            <TextView
                                android:id="@+id/tv_completed_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="3"
                                android:textColor="@color/black"
                                android:textStyle="bold"
                                android:textSize="18sp"
                                android:layout_marginTop="8dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="complete"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Quick Action Text -->
                <TextView
                    android:id="@+id/tv_quick_action"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quick action"
                    android:textColor="@color/text_main"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:layout_marginTop="24dp"
                    app:layout_constraintTop_toBottomOf="@id/card_stats"
                    app:layout_constraintStart_toStartOf="parent" />

                <!-- Action 1 -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/card_action_report"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_input"
                    android:layout_marginTop="16dp"
                    android:padding="16dp"
                    app:layout_constraintTop_toBottomOf="@id/tv_quick_action">

                    <FrameLayout
                        android:id="@+id/icon_bg_1"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_rounded_top_white"
                        android:backgroundTint="#EFF6FF"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_report_problem" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tv_action_1_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Report New Issue"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginStart="16dp"
                        app:layout_constraintTop_toTopOf="@id/icon_bg_1"
                        app:layout_constraintStart_toEndOf="@id/icon_bg_1" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Submit to campus complaint"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"
                        app:layout_constraintTop_toBottomOf="@id/tv_action_1_title"
                        app:layout_constraintStart_toStartOf="@id/tv_action_1_title" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_arrow_back"
                        android:rotation="180"
                        app:tint="@color/text_hint"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Action 2 -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/card_action_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_input"
                    android:layout_marginTop="12dp"
                    android:padding="16dp"
                    app:layout_constraintTop_toBottomOf="@id/card_action_report">

                    <FrameLayout
                        android:id="@+id/icon_bg_2"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_rounded_top_white"
                        android:backgroundTint="#EFF6FF"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            app:tint="@color/primary_blue"
                            android:src="@drawable/ic_check_circle" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tv_action_2_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="View my complaints"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginStart="16dp"
                        app:layout_constraintTop_toTopOf="@id/icon_bg_2"
                        app:layout_constraintStart_toEndOf="@id/icon_bg_2" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Track your submissions"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"
                        app:layout_constraintTop_toBottomOf="@id/tv_action_2_title"
                        app:layout_constraintStart_toStartOf="@id/tv_action_2_title" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_arrow_back"
                        android:rotation="180"
                        app:tint="@color/text_hint"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Recent Complaints Text -->
                <TextView
                    android:id="@+id/tv_recent_complaints"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Recent complaints"
                    android:textColor="@color/text_main"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:layout_marginTop="24dp"
                    app:layout_constraintTop_toBottomOf="@id/card_action_view"
                    app:layout_constraintStart_toStartOf="parent" />

                <!-- RecyclerView for Complaints -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvComplaints"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="24dp"
                    android:nestedScrollingEnabled="false"
                    app:layout_constraintTop_toBottomOf="@id/tv_recent_complaints"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:itemCount="2"
                    tools:listitem="@layout/item_complaint" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
