<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".MainActivity">

    <!-- Top Blue Section -->
    <View
        android:id="@+id/top_blue_bg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/primary_blue"
        app:layout_constraintHeight_percent="0.4"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_welcome_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Welcome to ReportIt"
        android:textColor="@color/white"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toTopOf="@+id/top_blue_bg"
        app:layout_constraintBottom_toTopOf="@+id/tv_welcome_desc"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/tv_welcome_desc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Your voice matters. Reportit issues\nand track their resolution."
        android:textColor="@color/white"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginTop="12dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        app:layout_constraintTop_toBottomOf="@id/tv_welcome_title"
        app:layout_constraintBottom_toBottomOf="@+id/top_blue_bg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Why Reportit? Section -->
    <TextView
        android:id="@+id/tv_why_reportit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Why Reportit?"
        android:textColor="@color/text_main"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        android:layout_marginStart="24dp"
        app:layout_constraintTop_toBottomOf="@id/top_blue_bg"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Feature 1 -->
    <ImageView
        android:id="@+id/iv_feature_1"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_lightning"
        android:layout_marginTop="20dp"
        android:layout_marginStart="24dp"
        app:layout_constraintTop_toBottomOf="@id/tv_why_reportit"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tv_feature_1_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Quick Reporting"
        android:textColor="@color/text_main"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintTop_toTopOf="@id/iv_feature_1"
        app:layout_constraintStart_toEndOf="@id/iv_feature_1"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_feature_1_desc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Submit complaints in seconds with our simple form. Add photos and location details."
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tv_feature_1_title"
        app:layout_constraintStart_toStartOf="@id/tv_feature_1_title"
        app:layout_constraintEnd_toEndOf="@id/tv_feature_1_title" />

    <!-- Feature 2 -->
    <ImageView
        android:id="@+id/iv_feature_2"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_shield_purple"
        android:layout_marginTop="24dp"
        android:layout_marginStart="24dp"
        app:layout_constraintTop_toBottomOf="@id/tv_feature_1_desc"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tv_feature_2_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Track Progress"
        android:textColor="@color/text_main"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintTop_toTopOf="@id/iv_feature_2"
        app:layout_constraintStart_toEndOf="@id/iv_feature_2"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_feature_2_desc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Monitor the status of your complaints in real-time and receive updates."
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tv_feature_2_title"
        app:layout_constraintStart_toStartOf="@id/tv_feature_2_title"
        app:layout_constraintEnd_toEndOf="@id/tv_feature_2_title" />

    <!-- Feature 3 -->
    <ImageView
        android:id="@+id/iv_feature_3"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_group_green"
        android:layout_marginTop="24dp"
        android:layout_marginStart="24dp"
        app:layout_constraintTop_toBottomOf="@id/tv_feature_2_desc"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tv_feature_3_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Community Impact"
        android:textColor="@color/text_main"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintTop_toTopOf="@id/iv_feature_3"
        app:layout_constraintStart_toEndOf="@id/iv_feature_3"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_feature_3_desc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Help improve campus facilities for everyone. Your feedback drives change."
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tv_feature_3_title"
        app:layout_constraintStart_toStartOf="@id/tv_feature_3_title"
        app:layout_constraintEnd_toEndOf="@id/tv_feature_3_title" />

    <!-- Buttons -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_login"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="Login With Flat Number \u2192"
        android:textAllCaps="false"
        android:textSize="16sp"
        app:cornerRadius="12dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toTopOf="@id/tv_terms"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_terms"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="By continuing, you agree to our Terms of Service and Privacy Policy"
        android:textColor="@color/text_main"
        android:textSize="10sp"
        android:gravity="center"
        android:layout_marginBottom="24dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>